---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Card from '../components/Card.astro';

const title = 'Simon Projects — Projektek teljeskörűen';
const description =
  'Professzionális IT és műszaki projekt menedzsment, AI integráció és tanácsadás. Simon András, Budapest.';

const services = [
  {
    title: 'Projekt Menedzsment',
    description:
      'Teljeskörű IT és műszaki projekt menedzsment — a tervezéstől a sikeres lezárásig.',
  },
  {
    title: 'Tervezés',
    description:
      'Igényfelmérés, terjedelem-, időbeli lefutás- és költségvetési terv készítése, projekt szervezet és metodológia strukturálása, kommunikációs stratégia kidolgozása.',
  },
  {
    title: 'Kivitelezés',
    description:
      'A projekt minden aspektusának irányítása, beleértve a csapattagokat, az alkalmazottakat és a szállítókat. A költségvetés és az ütemterv betartása.',
  },
  {
    title: 'Monitorozás',
    description:
      'Riportok és jelentések kialakítása a projekt előrehaladásáról. KPI-ok figyelemmel kísérése, egyéni igények szerinti riportálás.',
  },
  {
    title: 'Tanácsadás',
    description:
      'Metodika- és folyamatelemzés, egyéni és csoportos konzultációk. AI eszközök beillesztése a meglévő munkafolyamatokba.',
  },
  {
    title: 'Képzések és oktatások',
    description:
      'Egyéni és csoportos tréningek, döntéshozók és kulcsszereplők képzése új folyamatokról vagy rendszerekről.',
  },
];
---

<BaseLayout title={title} description={description}>
  <main>
    <HeroSection
      title="A hatékony partner a projektek világában"
      subtitle="Legyen tervezési, kivitelezési fázisban a projekt, vagy éppen egy projektmentési munkára van szükség — kész megoldásokkal segítek minden partneremnek."
      ctaText="Portfólióm megtekintése"
      ctaHref="/projects/"
    />

    <section class="client-carousel-section">
      <div class="container">
        <div class="client-carousel">
          <button class="carousel-btn carousel-prev" data-dir="-1" aria-label="Előző">&larr;</button>
          <div class="carousel-track">
            <span>MOL</span>
            <span>E.ON</span>
            <span>FlexLink</span>
            <span>SANYO</span>
            <span>Innobyte</span>
            <span>Kienle+Spiess</span>
            <span>Beck &amp; Pollitzer</span>
            <span>OPUS TITÁSZ</span>
            <span>MVM Next</span>
            <span>Procter &amp; Gamble</span>
            <span>MSD</span>
            <span>EYEBIZ</span>
            <span>NESTLÉ</span>
            <span>MARS</span>
            <span>PPF</span>
            <span>Arnott's</span>
          </div>
          <button class="carousel-btn carousel-next" data-dir="1" aria-label="Következő">&rarr;</button>
        </div>
      </div>
    </section>

    <section class="services">
      <div class="container">
        <h2>Szolgáltatásaink</h2>
        <div class="services-grid">
          {services.map((service) => (
            <Card title={service.title} description={service.description} />
          ))}
        </div>
      </div>
    </section>

    <section class="testimonial">
      <div class="container">
        <blockquote>
          <p>
            "Thanks for everything, I really liked working with you: even if you were an IT project manager, you fully captured the most important business points of the project, did not get lost in technical details, still you wanted to understand the main targets of the project and drive the whole story to the right way in line with the key stakeholders' expectations. You really stood out considering my previous experiences."
          </p>
          <footer>
            <cite>Gerebenics Máté</cite>
            <span>MOL Magyarország Kft.</span>
          </footer>
        </blockquote>
      </div>
    </section>

    <section class="contact-teaser">
      <div class="container">
        <h2>Dolgozzunk együtt</h2>
        <p>
          Nyitott vagyok új projektekre és együttműködésekre.
          Ha érdekel, hogyan segíthetek, keress bátran.
        </p>
        <a href="/contact/" class="cta-link">Kapcsolat &rarr;</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .client-carousel-section {
    padding-bottom: var(--space-3xl);
  }

  .client-carousel {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .carousel-track {
    display: flex;
    gap: var(--space-xl);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    flex: 1;
    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    padding: var(--space-sm) 0;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track span {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .carousel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 1rem;
    cursor: pointer;
    flex-shrink: 0;
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .carousel-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .services {
    padding: var(--space-4xl) 0;
  }

  .services h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-2xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .testimonial {
    padding: var(--space-5xl) 0;
    margin: var(--space-4xl) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-alt);
  }

  blockquote {
    max-width: 680px;
    margin-inline: auto;
    text-align: center;
    border: none;
    padding: 0;
    background: none;
  }

  blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    line-height: 1.9;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  blockquote footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  blockquote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  blockquote footer span {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .contact-teaser {
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .contact-teaser h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-lg);
  }

  .contact-teaser p {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    max-width: 500px;
    margin-inline: auto;
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .cta-link {
    font-weight: 600;
    font-size: 1.0625rem;
  }
</style>

<script is:inline>
  (function () {
    document.querySelectorAll('.client-carousel').forEach(function (carousel) {
      var track = carousel.querySelector('.carousel-track');
      if (!track) return;

      var items = Array.from(track.children);
      items.forEach(function (item) {
        track.appendChild(item.cloneNode(true));
      });

      var singleWidth = 0;
      var gap = parseFloat(getComputedStyle(track).gap) || 0;
      items.forEach(function (item) {
        singleWidth += item.offsetWidth;
      });
      singleWidth += gap * items.length;
      track.scrollLeft = singleWidth;

      track.addEventListener('scrollend', function () {
        if (track.scrollLeft <= 0) {
          track.style.scrollBehavior = 'auto';
          track.scrollLeft = singleWidth;
          track.style.scrollBehavior = 'smooth';
        } else if (track.scrollLeft >= singleWidth * 2 - track.offsetWidth) {
          track.style.scrollBehavior = 'auto';
          track.scrollLeft = singleWidth + (track.scrollLeft - singleWidth * 2 + track.offsetWidth);
          track.style.scrollBehavior = 'smooth';
        }
      });

      carousel.querySelectorAll('.carousel-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dir = parseInt(btn.getAttribute('data-dir'));
          track.scrollBy({ left: dir * 250, behavior: 'smooth' });
        });
      });
    });
  })();
</script>
