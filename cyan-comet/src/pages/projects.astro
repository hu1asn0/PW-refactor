---

<BaseLayout title={title} description={description}>
  <main class="container projects-page">
    <h1>Portfólióm</h1>
    <p class="intro">Eddigi munkáim címszavakban.</p>

    <div class="client-carousel">
      <button class="carousel-btn carousel-prev" data-dir="-1" aria-label="Előző">&larr;</button>
      <div class="carousel-track">
        <span>MOL</span>
        <span>E.ON</span>
        <span>FlexLink</span>
        <span>SANYO</span>
        <span>Innobyte</span>
        <span>Kienle+Spiess</span>
        <span>Beck &amp; Pollitzer</span>
        <span>OPUS TITÁSZ</span>
        <span>MVM Next</span>
        <span>Procter &amp; Gamble</span>
        <span>MSD</span>
        <span>EYEBIZ</span>
        <span>NESTLÉ</span>
        <span>MARS</span>
        <span>PPF</span>
        <span>Arnott's</span>
      </div>
      <button class="carousel-btn carousel-next" data-dir="1" aria-label="Következő">&rarr;</button>
    </div>

    <div class="timeline">
      {positions.map((pos) => (
        <article class="position">
          <div class="position-header">
            <h2>{pos.role}</h2>
            <p class="company">{pos.company}</p>
            <p class="period">{pos.period}</p>
          </div>
          {pos.description && <p class="position-desc">{pos.description}</p>}
          <ul>
            {pos.tasks.map((task) => (
              <li>{task}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .projects-page {
    padding: var(--space-4xl) 0;
    max-width: 800px;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-sm);
  }

  .intro {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    margin-bottom: var(--space-2xl);
  }

  .client-carousel {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-bottom: var(--space-2xl);
    margin-bottom: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .carousel-track {
    display: flex;
    gap: var(--space-xl);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    flex: 1;
    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);
    padding: var(--space-sm) 0;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track span {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .carousel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 1rem;
    cursor: pointer;
    flex-shrink: 0;
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .carousel-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .position {
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .position:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .position-header {
    margin-bottom: var(--space-md);
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
  }

  .company {
    font-weight: 500;
    color: var(--color-accent);
    font-size: 0.9375rem;
    margin-bottom: var(--space-xs);
  }

  .period {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .position-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    padding-left: var(--space-md);
    position: relative;
  }

  li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
</style>

<script is:inline>
  (function () {
    var track = document.querySelector('.carousel-track');
    if (!track) return;

    // Duplicate children for infinite loop
    var items = Array.from(track.children);
    items.forEach(function (item) {
      track.appendChild(item.cloneNode(true));
    });

    // Jump to middle set on load (so left arrow works immediately)
    var singleWidth = 0;
    items.forEach(function (item) {
      singleWidth += item.offsetWidth;
    });
    // account for gaps
    var gap = parseFloat(getComputedStyle(track).gap) || 0;
    singleWidth += gap * items.length;

    track.scrollLeft = singleWidth;

    // Reset position when scroll reaches edges
    track.addEventListener('scrollend', function () {
      if (track.scrollLeft <= 0) {
        track.style.scrollBehavior = 'auto';
        track.scrollLeft = singleWidth;
        track.style.scrollBehavior = 'smooth';
      } else if (track.scrollLeft >= singleWidth * 2 - track.offsetWidth) {
        track.style.scrollBehavior = 'auto';
        track.scrollLeft = singleWidth + (track.scrollLeft - singleWidth * 2 + track.offsetWidth);
        track.style.scrollBehavior = 'smooth';
      }
    });

    document.querySelectorAll('.carousel-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var dir = parseInt(btn.getAttribute('data-dir'));
        track.scrollBy({ left: dir * 250, behavior: 'smooth' });
      });
    });
  })();
</script>
