---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Legal Notice | András Simon — Sole Proprietor, Budapest';
const description = 'András Simon sole proprietor — legal information, tax number, contact details. IT project management and AI integration services based in Budapest, Hungary.';
---

<BaseLayout title={title} description={description}>
  <main class="container impresszum-page">
    <h1>Legal Notice</h1>

    <dl>
      <dt>Name</dt>
      <dd>Simon András Ev. (Sole Proprietor)</dd>

      <dt>Tax Number</dt>
      <dd>68487959-2-42</dd>

      <dt>Registration Number</dt>
      <dd>51817811</dd>

      <dt>Address</dt>
      <dd>1108 Budapest, Bányató utca 26., 6th floor, apt. 27.</dd>

      <dt>Bank Account</dt>
      <dd>11710002-24145552</dd>

      <dt>Bank</dt>
      <dd>OTP Bank</dd>
    </dl>
  </main>
</BaseLayout>

<style>
  .impresszum-page {
    padding: var(--space-4xl) 0;
    max-width: 600px;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-2xl);
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm) var(--space-xl);
  }

  dt {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  dd {
    font-size: 0.9375rem;
    color: var(--color-text);
  }
</style>
