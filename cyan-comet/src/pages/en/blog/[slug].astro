---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
import { fetchPosts, formatDate } from '../../../lib/beehiiv.js';

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const blogPostSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  image: post.image || undefined,
  datePublished: new Date(post.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.author || 'András Simon',
    url: 'https://simonprojects.eu/en/',
  },
  publisher: {
    '@type': 'Person',
    name: 'András Simon',
    url: 'https://simonprojects.eu/en/',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://simonprojects.eu/en/blog/${post.slug}/`,
  },
  keywords: post.categories?.join(', ') || undefined,
  inLanguage: 'en',
});
---

<BaseLayout title={post.title} description={post.description}>
  <main>
    <script type="application/ld+json" set:html={blogPostSchema} />
    <article class="post-article">
      <div class="container">
        <a href="/en/blog/" class="back-link">&larr; Back to blog</a>

        <header class="post-header">
          <time datetime={new Date(post.pubDate).toISOString()}>
            {formatDate(post.pubDate, 'en')}
          </time>
          <h1>{post.title}</h1>
          <p class="post-author">{post.author}</p>
          {post.categories.length > 0 && (
            <div class="post-tags">
              {post.categories.map((cat) => (
                <span class="tag">{cat}</span>
              ))}
            </div>
          )}
        </header>

        {post.image && (
          <div class="post-hero-image">
            <img src={post.image} alt={post.title} />
          </div>
        )}

        <div class="post-body" set:html={post.content} />

        <footer class="post-footer">
          <a href={post.link} target="_blank" rel="noopener" class="beehiiv-link">
            View original post on Beehiiv &rarr;
          </a>
        </footer>

        <NewsletterSignup />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .post-article {
    padding-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-xl);
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-header {
    margin-bottom: var(--space-2xl);
  }

  .post-header time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .post-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .post-author {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .post-hero-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
  }

  .post-hero-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-body {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-body :global(h1) {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-2xl) 0 var(--space-md);
    line-height: 1.2;
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin: var(--space-2xl) 0 var(--space-md);
    line-height: 1.25;
  }

  .post-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: var(--space-xl) 0 var(--space-sm);
    line-height: 1.3;
  }

  .post-body :global(p) {
    margin-bottom: var(--space-md);
  }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-lg);
    margin: var(--space-lg) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: var(--space-md) 0;
    padding-left: var(--space-xl);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .post-body :global(pre) {
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    overflow-x: auto;
    margin: var(--space-lg) 0;
    font-size: 0.9rem;
  }

  .post-body :global(code) {
    font-size: 0.9em;
    background-color: var(--color-bg-alt);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    text-align: left;
    font-size: 0.92rem;
  }

  .post-body :global(th) {
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  .post-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .beehiiv-link {
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
