---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { fetchPosts, formatDate } from '../../lib/beehiiv.js';

const title = 'Blog — Perplexity For Project Managers';
const description =
  'AI tips and practical guides for IT project managers. Newsletter by András Simon.';

const posts = await fetchPosts();
---

<BaseLayout title={title} description={description}>
  <main>
    <section class="blog-hero">
      <div class="container">
        <h1>Perplexity For<br /><em>Project Managers</em></h1>
        <p class="blog-subtitle">AI tips and practical guides for IT project managers</p>
      </div>
    </section>

    <section class="blog-list">
      <div class="container">
        {posts.length === 0 ? (
          <p class="empty-state">Articles coming soon...</p>
        ) : (
          <ul class="post-grid">
            {posts.map((post) => (
              <li>
                <a href={post.link} target="_blank" rel="noopener" class="post-card">
                  {post.image && (
                    <div class="post-image">
                      <img src={post.image} alt={post.title} loading="lazy" />
                    </div>
                  )}
                  <div class="post-content">
                    <time datetime={new Date(post.pubDate).toISOString()}>
                      {formatDate(post.pubDate, 'en')}
                    </time>
                    <h2>{post.title}</h2>
                    <p>{post.description}</p>
                    {post.categories.length > 0 && (
                      <div class="post-tags">
                        {post.categories.map((cat) => (
                          <span class="tag">{cat}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}

        <NewsletterSignup />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-hero {
    padding: var(--space-4xl) 0 var(--space-2xl);
    text-align: center;
  }

  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: var(--space-md);
  }

  .blog-hero em {
    font-style: italic;
    color: var(--color-accent);
  }

  .blog-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 520px;
    margin-inline: auto;
  }

  .blog-list {
    padding-bottom: var(--space-3xl);
  }

  .post-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      border-color var(--transition-fast),
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    color: inherit;
  }

  .post-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .post-card:hover .post-image img {
    transform: scale(1.03);
  }

  .post-content {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex-grow: 1;
  }

  .post-content time {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .post-content h2 {
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .post-content p {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg-alt);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-3xl);
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 680px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
