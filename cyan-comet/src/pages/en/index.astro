---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import Card from '../../components/Card.astro';

const title = 'Simon Projects — Full-scope Project Management';
const description =
  'Professional IT and technical project management, AI integration and consulting. András Simon, Budapest.';

const services = [
  {
    title: 'Project Management',
    description:
      'Full-scope IT and technical project management — from planning to successful delivery.',
    icon: 'clipboard-list',
  },
  {
    title: 'Planning',
    description:
      'Requirements analysis, scope definition, scheduling and budgeting, project organisation and methodology structuring, communication strategy development.',
    icon: 'compass',
  },
  {
    title: 'Execution',
    description:
      'Managing every aspect of the project, including team members, employees and vendors. Ensuring budget and schedule compliance.',
    icon: 'settings',
  },
  {
    title: 'Monitoring',
    description:
      'Creating reports on project progress. KPI tracking, custom reporting methodology tailored to individual needs.',
    icon: 'bar-chart',
  },
  {
    title: 'Consulting',
    description:
      'Methodology and process analysis, individual and group consultations. Integrating AI tools into existing workflows.',
    icon: 'lightbulb',
  },
  {
    title: 'Training & Education',
    description:
      'Individual and group trainings, educating decision-makers and key stakeholders on new processes or systems.',
    icon: 'users',
  },
];

const clients = ['MOL', 'E.ON', 'FlexLink', 'SANYO', 'Innobyte', 'Kienle+Spiess', 'Beck & Pollitzer', 'OPUS TITÁSZ', 'MVM Next', 'Procter & Gamble', 'MSD', 'EYEBIZ', 'NESTLÉ', 'MARS', 'PPF', "Arnott's"];
---

<BaseLayout title={title} description={description}>
  <main>
    <HeroSection
      title="Your reliable partner in the world of projects"
      highlightWord="projects"
      subtitle="Whether the project is in the planning or execution phase, or a project rescue is needed — I help every partner with ready-made solutions."
      ctaText="View my portfolio"
      ctaHref="/en/projects/"
      ctaSecondaryText="Contact"
      ctaSecondaryHref="/en/contact/"
      badgeText="Available for new projects"
    />

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-number" data-target="15">0</span><span class="stat-suffix">+</span>
            <span class="stat-label">Years of experience</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="50">0</span><span class="stat-suffix">+</span>
            <span class="stat-label">Delivered projects</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="16">0</span>
            <span class="stat-label">Industry partners</span>
          </div>
          <div class="stat-item">
            <span class="stat-number" data-target="5">0</span>
            <span class="stat-label">Countries</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Client Logo Marquee -->
    <div class="marquee-section">
      <div class="marquee-track">
        {[...clients, ...clients].map((name) => (
          <span class="marquee-item">{name}</span>
        ))}
      </div>
    </div>

    <!-- Services -->
    <section class="services">
      <div class="container">
        <h2 class="animate-on-scroll">Our Services</h2>
        <div class="services-grid">
          {services.map((service, i) => (
            <div class="animate-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <Card title={service.title} description={service.description} icon={service.icon} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <div class="testimonial">
      <div class="container">
        <div class="testimonial-inner animate-on-scroll">
          <div class="quote-mark" aria-hidden="true">"</div>
          <blockquote>
            <div class="stars">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <p>
              Thanks for everything, I really liked working with you: even if you were an IT project manager, you fully captured the most important business points of the project, did not get lost in technical details, still you wanted to understand the main targets of the project and drive the whole story to the right way in line with the key stakeholders' expectations. You really stood out considering my previous experiences.
            </p>
            <footer>
              <cite>Máté Gerebenics</cite>
              <span>MOL Hungary Ltd.</span>
            </footer>
          </blockquote>
        </div>
      </div>
    </div>

    <!-- Contact CTA -->
    <section class="contact-cta">
      <div class="container">
        <div class="cta-card animate-on-scroll">
          <h2>Let's work together</h2>
          <p>
            I'm open to new projects and collaborations.
            If you're interested in how I can help, feel free to reach out.
          </p>
          <a href="/en/contact/" class="cta-button">Contact</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== STATS BAR ===== */
  .stats-bar {
    background: var(--color-bg);
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    text-align: center;
  }

  .stat-item {
    position: relative;
  }

  .stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background: var(--color-border);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .stat-suffix {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* ===== MARQUEE ===== */
  .marquee-section {
    padding: var(--space-xl) 0;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .marquee-track {
    display: flex;
    gap: var(--space-3xl);
    animation: marquee 30s linear infinite;
    width: max-content;
  }

  .marquee-section:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.45;
    filter: grayscale(1);
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  .marquee-item:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  /* ===== SERVICES ===== */
  .services {
    padding: var(--space-4xl) 0;
    background: var(--color-bg-alt);
  }

  .services h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-2xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  /* ===== TESTIMONIAL ===== */
  .testimonial {
    background: #0f172a;
    border-top: 3px solid var(--accent);
    padding: var(--space-4xl) 0;
  }

  .testimonial-inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
    position: relative;
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    opacity: 0.3;
    margin-bottom: -2rem;
  }

  .stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: var(--space-lg);
  }

  blockquote {
    border: none;
    padding: 0;
    margin: 0;
    background: none;
  }

  blockquote p {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: var(--space-xl);
    font-style: italic;
  }

  blockquote footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  blockquote cite {
    font-style: normal;
    font-weight: 700;
    font-size: 1rem;
    color: #ffffff;
  }

  blockquote footer span {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
  }

  /* ===== CONTACT CTA ===== */
  .contact-cta {
    padding: var(--space-4xl) 0;
    background: var(--color-bg-alt);
  }

  .cta-card {
    background: rgba(255, 255, 255, 0.95);
    border-radius: var(--radius-2xl);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
    border-top: 1px solid rgba(255, 255, 255, 0.8);
    padding: var(--space-3xl) var(--space-2xl);
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  :global(.dark) .cta-card {
    background: rgba(30, 41, 59, 0.95);
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .cta-card h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-lg);
  }

  .cta-card p {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    max-width: 460px;
    margin-inline: auto;
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .cta-button {
    display: inline-block;
    background: #f59e0b;
    color: #0f172a;
    padding: 0.75rem 2rem;
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    transition: filter 0.25s ease, transform 0.25s ease;
    text-decoration: none;
  }

  .cta-button:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    color: #0f172a;
    text-decoration: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .stat-item:not(:last-child)::after {
      display: none;
    }
  }
</style>

<script>
  function initCountUp() {
    const statObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target || '0', 10);
            let current = 0;
            const duration = 1500;
            const step = target / (duration / 16);
            const counter = setInterval(() => {
              current += step;
              if (current >= target) {
                current = target;
                clearInterval(counter);
              }
              el.textContent = Math.floor(current).toString();
            }, 16);
            statObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    document.querySelectorAll('.stat-number[data-target]').forEach((el) => {
      statObserver.observe(el);
    });
  }

  initCountUp();
  document.addEventListener('astro:after-swap', initCountUp);
</script>
