---
import DarkModeToggle from './DarkModeToggle.astro';

const currentLocale = Astro.currentLocale || 'hu';
const isEn = currentLocale === 'en';
const currentPath = Astro.url.pathname;

const links = isEn
  ? [
      { href: '/en/', label: 'Home' },
      { href: '/en/about/', label: 'About' },
      { href: '/en/projects/', label: 'Portfolio' },
      { href: '/en/contact/', label: 'Contact' },
    ]
  : [
      { href: '/', label: 'Főoldal' },
      { href: '/about/', label: 'Rólam' },
      { href: '/projects/', label: 'Portfólióm' },
      { href: '/contact/', label: 'Elérhetőség' },
    ];

// Build the alternate language URL
const pathWithoutLocale = isEn
  ? currentPath.replace(/^\/en/, '') || '/'
  : currentPath;
const altHref = isEn ? pathWithoutLocale : `/en${currentPath === '/' ? '/' : currentPath}`;
const altLabel = isEn ? 'HU' : 'EN';
---

<nav class="site-nav">
  <div class="container nav-inner">
    <a href={isEn ? '/en/' : '/'} class="nav-brand">SIMON PROJECTS</a>

    <input type="checkbox" id="menu-toggle" class="sr-only" />
    <label for="menu-toggle" class="menu-button" aria-label={isEn ? 'Open menu' : 'Menü megnyitása'}>
      <span class="hamburger"></span>
    </label>

    <ul class="nav-links">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="nav-actions">
        <a href={altHref} class="lang-toggle">{altLabel}</a>
        <DarkModeToggle />
      </li>
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: background-color var(--transition-base);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-lg);
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text);
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .nav-brand:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    transition: color var(--transition-fast);
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-links a.active {
    color: var(--color-text);
    font-weight: 500;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .lang-toggle {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .lang-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .menu-button {
    display: none;
    cursor: pointer;
    padding: var(--space-xs);
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .hamburger::before {
    top: -7px;
  }

  .hamburger::after {
    top: 7px;
  }

  /* Hamburger animation when open */
  #menu-toggle:checked ~ .menu-button .hamburger {
    background-color: transparent;
  }

  #menu-toggle:checked ~ .menu-button .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  #menu-toggle:checked ~ .menu-button .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .menu-button {
      display: block;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background-color: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-lg);
      gap: var(--space-md);
    }

    #menu-toggle:checked ~ .nav-links {
      display: flex;
    }

    .nav-actions {
      padding-top: var(--space-sm);
      border-top: 1px solid var(--color-border);
      width: 100%;
      justify-content: center;
    }
  }
</style>
