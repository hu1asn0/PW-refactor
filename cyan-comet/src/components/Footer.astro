---
const year = new Date().getFullYear();
const isEn = (Astro.currentLocale || 'hu') === 'en';
---

<footer class="site-footer">
  <div class="container">
    <p>&copy; {year} Simon András e.v. — {isEn ? 'All rights reserved!' : 'Minden jog fenntartva!'}</p>
    <div class="footer-links">
      <a id="footer-email" href="#">...</a>
      <span class="separator">&middot;</span>
      <a href="/impresszum/">{isEn ? 'Legal notice' : 'Impresszum'}</a>
    </div>
  </div>
  <script>
    function initFooterEmail() {
      const u = 'info';
      const d = 'simonprojects.eu';
      const addr = `${u}@${d}`;
      const el = document.getElementById('footer-email');
      if (el) {
        (el as HTMLAnchorElement).href = `mailto:${addr}`;
        el.textContent = addr;
      }
    }
    initFooterEmail();
    document.addEventListener('astro:after-swap', initFooterEmail);
  </script>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
    margin-top: 0;
    text-align: center;
    background: var(--color-bg);
  }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-xs);
  }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
  }

  .separator {
    color: var(--color-text-muted);
  }
</style>
